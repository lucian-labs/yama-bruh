  "patchFormat": {
    "description": "21-element array per patch. Both banks use this format.",
    "fields": [
      { "index": 0,  "key": "cRatio",   "description": "Carrier frequency multiplier",    "range": "0.5, 1-15" },
      { "index": 1,  "key": "mRatio",   "description": "Modulator frequency multiplier",  "range": "0.5, 1-15" },
      { "index": 2,  "key": "mDepth",   "description": "FM modulation depth (radians)",   "range": "0-12.566" },
      { "index": 3,  "key": "cAttack",  "description": "Carrier attack time (seconds)",   "range": "0+" },
      { "index": 4,  "key": "cDecay",   "description": "Carrier decay time (seconds)",    "range": "0+" },
      { "index": 5,  "key": "cSustain", "description": "Carrier sustain level",           "range": "0-1" },
      { "index": 6,  "key": "cRelease", "description": "Carrier release time (seconds)",  "range": "0+" },
      { "index": 7,  "key": "feedback",  "description": "Modulator self-feedback (radians)", "range": "0-12.566" },
      { "index": 8,  "key": "cWave",    "description": "Carrier waveform index",          "range": "0-5" },
      { "index": 9,  "key": "mWave",    "description": "Modulator waveform index",        "range": "0-5" },
      { "index": 10, "key": "tremolo",  "description": "Tremolo depth (3.7 Hz AM LFO)",   "range": "0-1" },
      { "index": 11, "key": "vibrato",  "description": "Chip vibrato depth (6.4 Hz PM LFO)", "range": "0-1" },
      { "index": 12, "key": "ksr",      "description": "Key-rate scaling",                "range": "0-1" },
      { "index": 13, "key": "ksl",      "description": "Key-level scaling",               "range": "0-3" },
      { "index": 14, "key": "modLevel", "description": "Modulator output amplitude scale", "range": "0-1" },
      { "index": 15, "key": "egType",   "description": "Carrier envelope type (0=sustained, 1=percussive)", "range": "0-1" },
      { "index": 16, "key": "mAttack",  "description": "Modulator attack time (seconds)", "range": "0+" },
      { "index": 17, "key": "mDecay",   "description": "Modulator decay time (seconds)",  "range": "0+" },
      { "index": 18, "key": "mSustain", "description": "Modulator sustain level",         "range": "0-1" },
      { "index": 19, "key": "mRelease", "description": "Modulator release time (seconds)", "range": "0+" },
      { "index": 20, "key": "mEgType",  "description": "Modulator envelope type (0=sustained, 1=percussive)", "range": "0-1" }
    ]
  }
