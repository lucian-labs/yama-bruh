{
  "name": "YAMA-BRUH",
  "version": "1.0.0",
  "description": "Deterministic 2-operator FM synth ringtone generator. Seeded PRNG + YM2413-style synthesis = same seed, same sound, every time.",
  "url": "https://yama-bruh.lucianlabs.ca",
  "script": "https://yama-bruh.lucianlabs.ca/yamabruh-notify.js",

  "parameters": {
    "seed": { "type": "string", "description": "Instance/app seed — prefixes patch + melody seeds for app-wide identity" },
    "patchSeed": { "type": "string", "description": "Patch seed — combined with instance seed to determine FM preset (timbre)" },
    "preset": { "type": "integer", "min": 0, "max": 99, "description": "Explicit preset index — overrides patchSeed when set" },
    "mode": { "type": "integer", "min": 0, "max": 9, "default": 1, "description": "Mood index — controls scale pool, note movement, resolution" },
    "bpm": { "type": "integer", "default": 140, "description": "Tempo in beats per minute" },
    "volume": { "type": "number", "min": 0, "max": 1, "default": 0.8, "description": "Master volume" },
    "sampleRate": { "type": "integer", "default": 44100, "description": "Sample rate in Hz" },
    "minLength": { "type": "integer", "min": 1, "default": null, "description": "Minimum number of notes — overrides the mode's default range" },
    "maxLength": { "type": "integer", "min": 1, "default": null, "description": "Maximum number of notes — overrides the mode's default range" }
  },

  "modes": [
    { "index": 0, "name": "pretty",       "resolves": true,  "character": "Major/pentatonic, stepwise, bright" },
    { "index": 1, "name": "experimental",  "resolves": false, "character": "All 39 scales, wild, full range" },
    { "index": 2, "name": "depressing",    "resolves": false, "character": "Minor/Phrygian, descending, slow, low" },
    { "index": 3, "name": "spooky",        "resolves": false, "character": "Diminished/whole-tone, tritones, large jumps" },
    { "index": 4, "name": "dreamy",        "resolves": true,  "character": "Lydian/pentatonic, floaty, long sustains" },
    { "index": 5, "name": "aggressive",    "resolves": false, "character": "Phrygian/blues, fast, low, wide intervals" },
    { "index": 6, "name": "exotic",        "resolves": false, "character": "Double harmonic/Persian/Arabian/gypsy" },
    { "index": 7, "name": "jazzy",         "resolves": true,  "character": "Dorian/bebop, chromatic passing tones" },
    { "index": 8, "name": "ethereal",      "resolves": true,  "character": "Whole-tone/augmented, wide intervals" },
    { "index": 9, "name": "mechanical",    "resolves": false, "character": "Diminished/whole-tone, repetitive, fast" }
  ],

  "banks": [
